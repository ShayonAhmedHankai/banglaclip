modules = ["nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["node", "dist/index.js"]
build = ["pnpm", "build"]

[userenv]

[userenv.shared]
VITE_FIREBASE_PROJECT_ID = "banglaclip-5ed15"
VITE_FIREBASE_AUTH_DOMAIN = "banglaclip-5ed15.firebaseapp.com"
VITE_FIREBASE_STORAGE_BUCKET = "banglaclip-5ed15.appspot.com"
