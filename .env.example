# ==============================================================================
# BanglaClip Environment Variables
# ==============================================================================
# This file serves as a template for your local .env file.
# Copy this file to .env and fill in the values.
# ==============================================================================

# ─── 1. REQUIRED - Core Functionality ─────────────────────────────────────────
# These must be set for the application to start and for the pipeline to work.

# PostgreSQL Database
# Setup: Use a local Postgres instance or a cloud provider (e.g., Supabase, Neon)
# Format: postgresql://user:password@host:5432/banglaclip
DATABASE_URL=postgresql://user:password@host:5432/banglaclip

# Firebase Service Account (Server-side)
# Setup: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Action: Paste the entire content of the downloaded JSON file as a single line
# Needed for: Authentication, Firestore data management
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Owner Firebase UID
# Setup: Firebase Console > Authentication > Users
# Action: Copy the UID of your primary admin user
# Needed for: Administrative access and project ownership checks
OWNER_FIREBASE_UID=

# Forge API (Core Infrastructure)
# Description: Unified API for S3 storage, Whisper transcription, and LLM processing.
# Setup: Contact maintainer for access or provide your own proxy endpoints.
# Needed for: Video storage, Bengali transcription, and AI metadata extraction.
BUILT_IN_FORGE_API_URL=https://api.example-forge.com
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here

# ─── 2. REQUIRED - Firebase Client (Public) ──────────────────────────────────
# These are exposed to the frontend. Get them from:
# Firebase Console > Project Settings > General > Your apps (Web App)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── 3. OPTIONAL - Enhanced Features ──────────────────────────────────────────
# These enable additional pipeline stages but are not strictly required for the app to run.

# YouTube OAuth (YouTube Upload Stage)
# Setup: Google Cloud Console > Enable YouTube Data API v3 > Create OAuth 2.0 Client ID
# Redirect URI: http://localhost:5000/api/youtube/callback (for local dev)
# Note: If missing, the YouTube upload feature will be disabled.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/youtube/callback

# Pexels API (B-Roll Overlay Stage)
# Setup: Sign up for a free key at https://www.pexels.com/api/
# Cost: Free tier (200 requests/hour)
# Fallback: If missing or rate-limited, the pipeline skips B-roll and continues to export.
PEXELS_API_KEY=

# ─── 4. NOTES ─────────────────────────────────────────────────────────────────
# 1. Never commit your actual .env file to version control.
# 2. For local development, 'pnpm dev' will load variables from .env.
# 3. If you encounter "Forge API not configured" errors, check your BUILT_IN_FORGE_API_* keys.
