# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/banglaclip

# ─── Firebase (server-side) ───────────────────────────────────────────────────
# Full JSON from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
# Firebase UID of the app owner — gets admin role automatically
OWNER_FIREBASE_UID=

# ─── Firebase (client-side, public) ───────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Forge API (storage + Whisper AI) ─────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── YouTube OAuth (optional) ─────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Add authorized redirect URI: https://yourdomain.com/api/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://yourdomain.com/api/youtube/callback

# ─── Pexels B-Roll (optional) ─────────────────────────────────────────────────
# Free API key at https://www.pexels.com/api/
PEXELS_API_KEY=
